# ===========================================
# News 맥락 분석 - Apache 설정
# ===========================================
# SPA: /news/123 등 존재하지 않는 경로 접속 시에도 index.php로 HTML 제공
ErrorDocument 404 /index.php

# 디렉토리 trailing slash 자동 리다이렉트 방지
# (api/auth/kakao 등 PHP 파일과 동명의 디렉토리가 있으면 mod_dir이 301로 /를 붙여버림)
DirectorySlash Off

# Rewrite 엔진 활성화
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Authorization 헤더를 PHP로 전달 (CGI에서 제거되는 경우 대비)
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # HTTPS 리다이렉트 (옵션)
    # RewriteCond %{HTTPS} off
    # RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # 카카오 로그인 경로 직접 처리 (trailing slash 호환)
    RewriteRule ^api/auth/kakao/?$ api/auth/kakao.php [L]
    RewriteRule ^api/auth/kakao/callback/?$ api/auth/kakao/callback.php [QSA,L]
    RewriteRule ^api/auth/kakao/token/?$ api/auth/kakao/token.php [QSA,L]
    # Google 로그인 (api.php 라우터 경유)
    RewriteRule ^api/auth/google/?$ api.php?__path=/api/auth/google [QSA,L]
    RewriteRule ^api/auth/google/callback/?$ api.php?__path=/api/auth/google/callback [QSA,L]
    # 회원 탈퇴 (가입 동의 거부 시)
    RewriteRule ^api/auth/withdraw/?$ api/auth/withdraw.php [QSA,L]
    # 구독 결제 API
    RewriteRule ^api/subscription/order$ api/subscription/order.php [QSA,L]
    RewriteRule ^api/subscription/verify$ api/subscription/verify.php [QSA,L]
    RewriteRule ^api/subscription/verify-promo$ api/subscription/verify-promo.php [QSA,L]
    RewriteRule ^api/subscription/status$ api/subscription/status.php [QSA,L]
    RewriteRule ^api/subscription/detail$ api/subscription/detail.php [QSA,L]
    RewriteRule ^api/subscription/auto-renew$ api/subscription/auto-renew.php [QSA,L]
    RewriteRule ^api/subscription/cancel$ api/subscription/cancel.php [QSA,L]
    RewriteRule ^api/subscription/settings$ api/subscription/settings.php [QSA,L]
    # StepPay 웹훅
    RewriteRule ^api/webhook/steppay$ api/webhook/steppay.php [QSA,L]
    RewriteRule ^api/subscription/test-steppay$ api/subscription/test-steppay.php [QSA,L]
    # 관리자 계정 생성 (1회 실행용)
    RewriteRule ^api/auth/seed-admin-user$ api/auth/seed-admin-user.php [QSA,L]
    # 분석 API 직접 처리
    RewriteRule ^api/analysis/news/([0-9]+)$ api/analysis/news.php [QSA,L]

    RewriteRule ^api/admin/promotion-codes$ api/admin/promotion-codes.php [QSA,L]
    # Admin API는 항상 Router 경유 (인증 + JSON 에러 래핑)
    RewriteRule ^api/admin/(.+\.php)$ api.php?__path=/api/admin/$1 [QSA,L]

    # API 요청: api.php로 라우팅 (파일이 없는 경우)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^api/(.*)$ api.php?__path=/api/$1 [QSA,L]

    # 정적 파일은 직접 제공 (PHP 파일 포함)
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^ - [L]

    # 디렉토리는 직접 제공 (API 경로 제외)
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteCond %{REQUEST_URI} !^/api/
    RewriteRule ^ - [L]

    # React SPA 라우팅 지원
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.php [QSA,L]
</IfModule>

# 오디오 파일 MIME 타입 및 CORS
<IfModule mod_mime.c>
    AddType audio/wav .wav
    AddType audio/mpeg .mp3
</IfModule>

# storage/audio 디렉토리의 오디오 파일에 CORS 허용
<IfModule mod_headers.c>
    <FilesMatch "\.(wav|mp3|ogg)$">
        Header set Access-Control-Allow-Origin "*"
        Header set Accept-Ranges "bytes"
    </FilesMatch>
</IfModule>

# 보안 헤더
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-XSS-Protection "1; mode=block"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Gzip 압축
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
    AddOutputFilterByType DEFLATE text/javascript application/javascript application/json
</IfModule>

# 캐시 설정
<IfModule mod_expires.c>
    ExpiresActive On
    
    # 이미지
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/gif "access plus 1 month"
    ExpiresByType image/svg+xml "access plus 1 month"
    ExpiresByType image/webp "access plus 1 month"
    
    # CSS/JS
    ExpiresByType text/css "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
    
    # 폰트
    ExpiresByType font/woff2 "access plus 1 month"
    ExpiresByType font/woff "access plus 1 month"
</IfModule>

# PWA 아이콘: 짧은 캐시 (1시간) — mod_expires의 30일 캐시를 덮어씀
<IfModule mod_headers.c>
    <FilesMatch "^(icon-|apple-icon|favicon).*\.(png|ico)$">
        Header set Cache-Control "public, max-age=3600, must-revalidate"
        Header unset Expires
    </FilesMatch>
</IfModule>

# 디렉토리 목록 비활성화
Options -Indexes

# php_value 제거: 닷홈(FastCGI/PHP-FPM)에서 500 유발. 필요시 php.ini 또는 호스팅 패널에서 설정

# 민감한 파일 접근 차단 (닷홈 호환: 모듈 없으면 스킵)
<IfModule mod_authz_core.c>
    <FilesMatch "\.(env|sql|md|json|lock|yml|yaml)$">
        Require all denied
    </FilesMatch>
    <FilesMatch "^\.">
        Require all denied
    </FilesMatch>
</IfModule>
