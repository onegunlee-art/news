    "n_stance_card_half": {
      "layer": "stance",
      "coach_text": "솔직하네. 입장이 판에 잡혔어.\n왜 그렇게 반반으로 보는지 — 이유를 따져보자.",
      "board_pulse": "stance",
      "choices": [
        { "id": "not_sure", "label": "장단이 있어서", "next": "n_reason_why2" },
        { "id": "need_more", "label": "더 알아봐야 해서", "next": "n_reason_why2" },
