      "choices": [
        { "id": "limits", "label": "핵은 안전을 주지만 한계가 있다", "next": "n_refine_card", "emit_card": { "layer": "refine", "text": "핵은 억지력을 주지만, 쓰기 어렵고 값싼 무기 앞엔 한계" } },
        { "id": "still_best", "label": "여전히 핵이 최선이다", "next": "n_refine_card_best", "emit_card": { "layer": "refine", "text": "한계는 있지만 핵 억지가 여전히 최선" } },
        { "id": "refine_free", "label": "직접 쓸게", "next": "n_refine_input", "input_mode": "text", "emit_card_on_message": { "layer": "refine" } }
