    "n_counter_drone": {
      "layer": "counter",
      "coach_text": "괜찮아. 천천히 보자. 드론 수천 대 vs 핵 — 뭐가 더 실제로 쓰일까?",
      "choices": [
        { "id": "drones_real", "label": "드론이 더 현실적", "next": "n_counter_hard" },
