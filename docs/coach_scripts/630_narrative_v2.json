    "n_depth_0": {
      "layer": "depth",
      "coach_text": "한 걸음 더. '보복이 무서워서'가 — 항상 통할까?\n상대가 잃을 게 없다면? 예를 들어 테러 집단처럼.",
      "choices": [
        { "id": "wont_work", "label": "안 통할 것 같아", "next": "n_depth_1" },
        { "id": "still_works", "label": "그래도 통해", "next": "n_depth_1" },
        { "id": "hard_depth", "label": "어렵다", "next": "n_depth_1" }
