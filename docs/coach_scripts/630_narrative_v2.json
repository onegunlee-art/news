    "n_intro": {
      "layer": "intro",
      "coach_text": "1945년 이후, 핵을 가진 나라끼리 전면전이 한 번도 없었어.\n미국도, 소련도, 중국도... 서로 으르렁댔지만 진짜 큰 전쟁은 없었어.\n\n왜 그랬을까?",
      "choices": [
        { "id": "nuclear_fear", "label": "핵이 무서워서", "next": "n_stance_bridge_fear" },
        { "id": "just_luck", "label": "운이 좋아서", "next": "n_stance_bridge_luck" },
        { "id": "other_reason", "label": "다른 이유", "next": "n_stance_bridge_other" }
      ]
    },
    "n_stance_bridge_fear": {
      "layer": "stance",
      "coach_text": "맞아, 서로 무서우니까. 이걸 **'억지력'** 이라고 해.\n그럼 — 우리나라도 핵을 가지면 안전할까? 네 생각은?",
      "choices": [
        { "id": "want_nuclear", "label": "가지는 게 안전해", "next": "n_stance_card", "emit_card": { "layer": "stance", "text": "핵이 있으면 우리도 안전하다" } },
        { "id": "no_nuclear", "label": "안 가지는 게 나아", "next": "n_stance_card_no", "emit_card": { "layer": "stance", "text": "핵 없이도 안전을 지킬 수 있다" } },
        { "id": "half_half", "label": "반반이야", "next": "n_stance_card_half", "emit_card": { "layer": "stance", "text": "핵이 완전한 답은 아닐 수 있다" } }
      ]
    },
    "n_stance_bridge_luck": {
      "layer": "stance",
      "coach_text": "그럴 수도 있지. 많은 사람은 '핵이 무서워서'라고 말해 — **억지력** 이야.\n우리나라도 핵을 가지면 안전할까?",
      "choices": [
        { "id": "want_nuclear", "label": "가지는 게 안전해", "next": "n_stance_card", "emit_card": { "layer": "stance", "text": "핵이 있으면 우리도 안전하다" } },
        { "id": "no_nuclear", "label": "안 가지는 게 나아", "next": "n_stance_card_no", "emit_card": { "layer": "stance", "text": "핵 없이도 안전을 지킬 수 있다" } },
        { "id": "half_half", "label": "반반이야", "next": "n_stance_card_half", "emit_card": { "layer": "stance", "text": "핵이 완전한 답은 아닐 수 있다" } }
      ]
    },
    "n_stance_bridge_other": {
      "layer": "stance",
      "coach_text": "다른 이유도 있겠지. 그중 하나가 **억지력** — 건드리면 같이 망한다는 생각이야.\n우리나라도 핵을 가지면 안전할까?",
      "choices": [
        { "id": "want_nuclear", "label": "가지는 게 안전해", "next": "n_stance_card", "emit_card": { "layer": "stance", "text": "핵이 있으면 우리도 안전하다" } },
        { "id": "no_nuclear", "label": "안 가지는 게 나아", "next": "n_stance_card_no", "emit_card": { "layer": "stance", "text": "핵 없이도 안전을 지킬 수 있다" } },
        { "id": "half_half", "label": "반반이야", "next": "n_stance_card_half", "emit_card": { "layer": "stance", "text": "핵이 완전한 답은 아닐 수 있다" } }
