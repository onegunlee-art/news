    "n_reason_card": {
      "layer": "reason",
      "coach_text": "완벽해. 이제 '입장'에 '근거'가 붙었어. **판을 봐** — 생각이 서기 시작했지?",
      "board_pulse": "reason",
      "choices": [
        { "id": "see_board", "label": "판 보니까 그렇네", "next": "n_depth_0" }
