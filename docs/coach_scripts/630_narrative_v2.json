        { "id": "conditional", "label": "조건이 있네", "next": "n_depth_card", "emit_card": { "layer": "depth", "text": "억지력은 '잃을 게 있는 상대'에게만 통함" } },
        { "id": "mostly_ok", "label": "그래도 대부분 맞아", "next": "n_depth_card_mostly", "emit_card": { "layer": "depth", "text": "대부분은 통하지만 예외가 있다" } }
      ]
