# ============================================
# 데이터베이스 설정 (필수)
# ============================================
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=ailand
DB_USERNAME=ailand
DB_PASSWORD=

# ============================================
# 보안 설정 (필수)
# ============================================
# JWT 토큰 서명용 비밀키 (32자 이상 랜덤 문자열 권장)
JWT_SECRET=

# ============================================
# API 키 설정
# ============================================

# OpenAI API 키 (글 요약/분석 GPT, 썸네일 이미지 생성 DALL·E)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# OpenAI Organization Admin API 키 (선택) - Usage API 사용량 조회용
# https://platform.openai.com/settings/organization/api-keys
# OPENAI_ADMIN_KEY=

# Google Cloud Text-to-Speech API 키 (TTS 음성 생성용)
# https://console.cloud.google.com/apis/credentials
GOOGLE_TTS_API_KEY=

# Anthropic Claude API 키 (AI 분석용)
ANTHROPIC_API_KEY=
