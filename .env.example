# ============================================
# 데이터베이스 설정 (필수)
# ============================================
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=ailand
DB_USERNAME=ailand
DB_PASSWORD=

# ============================================
# 보안 설정 (필수)
# ============================================
# JWT 토큰 서명용 비밀키 (32자 이상 랜덤 문자열 권장)
JWT_SECRET=

# StepPay API (필수 — config/app.php에서 하드코딩 폴백 없음)
# 대시보드에서 발급한 Secret-Token / Payment Key
STEPPAY_SECRET_TOKEN=
STEPPAY_PAYMENT_KEY=
# 웹훅 요청 헤더(X-Webhook-Secret 등) 검증용. 미설정 시 모든 웹훅이 403으로 거부됩니다.
STEPPAY_WEBHOOK_SECRET=

# seed 엔드포인트 보호 (프로덕션 권장): 설정 시 ?secret= 또는 X-Seed-Secret 없이는 seed 접근 불가
# SEED_SECRET=

# ============================================
# API 키 설정
# ============================================

# OpenAI API 키 (글 요약/분석 GPT, 썸네일 이미지 생성 DALL·E)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# OpenAI Organization Admin API 키 (선택) - Usage API 사용량 조회용
# https://platform.openai.com/settings/organization/api-keys
# OPENAI_ADMIN_KEY=

# Google Cloud Text-to-Speech API 키 (TTS 음성 생성용)
# https://console.cloud.google.com/apis/credentials
GOOGLE_TTS_API_KEY=

# Anthropic Claude API 키 (AI 분석용)
ANTHROPIC_API_KEY=

# ============================================
# Redis 설정 (선택 - Rate Limiting 성능 향상)
# ============================================
# Redis가 없으면 파일 기반 fallback 사용
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# ============================================
# CORS 설정 (선택)
# ============================================
# 쉼표로 구분된 허용 도메인 목록
# CORS_ORIGINS=https://thegist.co.kr,https://www.thegist.co.kr

# ============================================
# 기사 챗봇 설정 (선택)
# ============================================
# 기능 활성화 (false면 503 반환)
# ARTICLE_CHAT_ENABLED=false
# 베타 허용 이메일 목록 (쉼표 구분, 비어있으면 모든 인증 사용자 허용)
# ARTICLE_CHAT_ALLOWED_EMAILS=test@test.com
