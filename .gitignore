# Dependencies
node_modules/
vendor/

# Build outputs
dist/
build/

# Environment files
.env
.env.local
.env.*.local

# Config files (실제 값 포함)
config/database.php
# 예제 파일은 커밋됨: config/*.example.php

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Logs
logs/
*.log
npm-debug.log*

# Cache
.cache/
storage/cache/*
!storage/cache/.gitkeep
storage/jobs/*.json

# Temporary files
tmp/
temp/
temp_*.php

# Test coverage
coverage/

# Package locks (optional - some teams prefer to commit these)
# package-lock.json

# PHP specific
composer.lock

# Uploads
uploads/*
!uploads/.gitkeep

# Generated files
public/assets/*
!public/assets/.gitkeep
public/*.js
!public/sw.js
public/*.css
public/*.map

# Keep directories
!.gitkeep

# Android TWA 서명 키 (절대 커밋 금지)
android/**/*.jks
android/**/*.keystore
android/**/*.pepk

# AWS / EC2 (키·비밀번호·로컬 전용 스크립트 — 커밋 금지)
aws/thegist-key.pem
aws/env-ec2
aws/setup_mysql.sql
aws/backup-mysql.sh
aws/test_db.php
aws/test_detail.php
aws/check_*.py
